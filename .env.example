# ─────────────────────────────────────────────────────────────
# floating-posters  —  environment variable reference
# These go in docker-compose.yml environment section.
# Per-video settings (font, posters, timing, messages etc.)
# are set in each video's .yaml file instead.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
RADARR_URL=http://your-radarr:7878
RADARR_API_KEY=your_radarr_api_key

SONARR_URL=http://your-sonarr:8989      # only needed for tv: yaml files
SONARR_API_KEY=your_sonarr_api_key

# ── Directory paths (inside container) ───────────────────────
INPUT_DIR=/input       # scan folder with video + yaml pairs
OUTPUT_DIR=/output     # where rendered videos are saved

# ── CPU & quality ─────────────────────────────────────────────
CPU_THREADS=2          # FFmpeg thread limit (0 = unlimited)
VIDEO_CRF=18           # 18=near-lossless  23=default  28=smaller
VIDEO_PRESET=fast      # ultrafast / fast / medium / slow
