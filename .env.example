# ─────────────────────────────────────────────────────────────
# floating-posters  —  environment variable reference
# Copy to .env and fill in your values, or set these directly
# in your docker-compose.yml environment section.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
RADARR_URL=http://your-radarr-host:7878
RADARR_API_KEY=your_api_key_here

# ── File paths (inside the container) ────────────────────────
INPUT_VIDEO=/input/background.mp4
OUTPUT_VIDEO=/output/output.mp4

# ── Font ──────────────────────────────────────────────────────
# Available fonts (all included in the Docker image):
#   Poppins-Bold, Poppins-Medium, Poppins-Regular
#   DejaVuSans-Bold, DejaVuSans, DejaVuSerif-Bold, DejaVuSerif
#   DejaVuSansMono-Bold, DejaVuSansCondensed-Bold
#   LiberationSans-Bold, LiberationSans, LiberationSerif-Bold, LiberationMono-Bold
#   FreeSansBold, FreeSerifBold
#   Carlito-Bold, Caladea-Bold
FONT=Poppins-Bold

# ── Timing ───────────────────────────────────────────────────
START_TIME=2.0          # Seconds into video where posters first appear
POSTER_DURATION=8.0     # How long posters are visible (max 10)
FADE_DURATION=0.75      # Fade in/out duration in seconds

# ── Poster selection ─────────────────────────────────────────
NUM_POSTERS=4           # Number of posters to show at once (1–6)
UPCOMING_DAYS=180       # Look this many days ahead in Radarr

# ── Poster appearance ─────────────────────────────────────────
POSTER_WIDTH=185        # Poster width in pixels (height auto-scales)
PADDING=28              # Pixels of space between posters
VERTICAL_POS=0.52       # Vertical position: 0.0=top  0.5=center  1.0=bottom
CORNER_RADIUS=10        # Rounded corner radius in pixels

# ── Drop shadow ───────────────────────────────────────────────
ADD_SHADOW=true
SHADOW_OFFSET_X=7
SHADOW_OFFSET_Y=9
SHADOW_BLUR=9
SHADOW_OPACITY=175      # 0 (invisible) to 255 (solid black)

# ── Release date label ────────────────────────────────────────
SHOW_RELEASE_DATE=true          # Show release date below each poster
RELEASE_DATE_COLOR=#FFFFFF      # Hex (#RRGGBB) or CSS color name
RELEASE_DATE_SIZE=15            # Font size in pixels
RELEASE_DATE_SHADOW=true        # Drop shadow behind text

# ── Top message ───────────────────────────────────────────────
TOP_MESSAGE_SHOW=false          # Set true to enable
TOP_MESSAGE=Coming Soon         # Text to display
TOP_MESSAGE_ADD_DATE=false      # Append today's date
TOP_MESSAGE_COLOR=white         # Hex or CSS color name
TOP_MESSAGE_SIZE=15             # Font size in pixels
TOP_MESSAGE_SHADOW=false        # Drop shadow behind text

# ── Bottom message ────────────────────────────────────────────
BOTTOM_MESSAGE_SHOW=false       # Set true to enable
BOTTOM_MESSAGE=Updated          # Text to display
BOTTOM_MESSAGE_ADD_DATE=true    # Append today's date: "Updated  April 20, 2026"
BOTTOM_MESSAGE_COLOR=white      # Hex or CSS color name
BOTTOM_MESSAGE_SIZE=15          # Font size in pixels
BOTTOM_MESSAGE_SHADOW=false     # Drop shadow behind text

# ── CPU throttle ──────────────────────────────────────────────
CPU_THREADS=2                   # FFmpeg thread limit (0 = auto/unlimited)

# ── Output encoding ───────────────────────────────────────────
VIDEO_CRF=18            # Quality: 18=near-lossless  23=default  28=small file
VIDEO_PRESET=fast       # Speed: ultrafast / fast / medium / slow
