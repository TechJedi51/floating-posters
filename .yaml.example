# ─────────────────────────────────────────────────────────────
# floating-posters  —  per-video yaml reference
#
# Name this file the same as your video file:
#   MyBackground.mov  →  MyBackground.yaml
#
# Top-level key:
#   movie:  →  fetches posters from Radarr
#   tv:     →  fetches posters from Sonarr
# ─────────────────────────────────────────────────────────────

movie:
  # Output filename (saved to /output as <output>.mp4)
  - output=MyPreroll

  # ── Font ────────────────────────────────────────────────────
  # Poppins-Bold, Poppins-Medium, Poppins-Regular,
  # DejaVuSans-Bold, DejaVuSans, DejaVuSerif-Bold, DejaVuSerif,
  # DejaVuSansMono-Bold, DejaVuSansCondensed-Bold,
  # LiberationSans-Bold, LiberationSans, LiberationSerif-Bold, LiberationMono-Bold,
  # FreeSansBold, FreeSerifBold, Carlito-Bold, Caladea-Bold
  - FONT=Poppins-Bold

  # ── Poster selection ────────────────────────────────────────
  - NUM_POSTERS=5          # 1–10  (6+ triggers 2-row layout)
  - UPCOMING_DAYS=180

  # ── Timing ──────────────────────────────────────────────────
  - START_TIME=3.0
  - POSTER_DURATION=9.0
  - FADE_DURATION=0.75

  # ── Poster appearance ────────────────────────────────────────
  - POSTER_WIDTH=250
  - PADDING=28
  - ROW_GAP=24             # pixels between rows (2-row layout only)
  - VERTICAL_POS=0.52      # 0.0=top  0.5=center  1.0=bottom
  - CORNER_RADIUS=10

  # ── Drop shadow ──────────────────────────────────────────────
  - ADD_SHADOW=true
  - SHADOW_OFFSET_X=7
  - SHADOW_OFFSET_Y=9
  - SHADOW_BLUR=9
  - SHADOW_OPACITY=175

  # ── Release date label ───────────────────────────────────────
  - SHOW_RELEASE_DATE=true
  - RELEASE_DATE_COLOR=#FFFFFF
  - RELEASE_DATE_SIZE=15
  - RELEASE_DATE_SHADOW=true
  - RELEASE_DATE_BG_COLOR=#000000    # pill background color
  - RELEASE_DATE_BG_OPACITY=170      # 0=no background  255=solid

  # ── Top message ──────────────────────────────────────────────
  - TOP_MESSAGE_SHOW=false
  - TOP_MESSAGE=Coming Soon
  - TOP_MESSAGE_ADD_DATE=false
  - TOP_MESSAGE_COLOR=white
  - TOP_MESSAGE_SIZE=15
  - TOP_MESSAGE_SHADOW=false
  - TOP_MESSAGE_BG_COLOR=#000000
  - TOP_MESSAGE_BG_OPACITY=170

  # ── Bottom message ───────────────────────────────────────────
  - BOTTOM_MESSAGE_SHOW=false
  - BOTTOM_MESSAGE=Updated
  - BOTTOM_MESSAGE_ADD_DATE=true
  - BOTTOM_MESSAGE_COLOR=white
  - BOTTOM_MESSAGE_SIZE=15
  - BOTTOM_MESSAGE_SHADOW=false
  - BOTTOM_MESSAGE_BG_COLOR=#000000
  - BOTTOM_MESSAGE_BG_OPACITY=170

  # ── Animation style ─────────────────────────────────────────
  # bounce    — sine-wave vertical float (default)
  # fade      — static positions, fade in/out only
  # wave      — left-to-right cascade with staggered delay
  # pop-in    — each poster scales from large down to grid, staggered
  # carousel  — elliptical 3-D style rotation
  # spotlight — one poster at a time, large & centred, cycling through all
  # drift     — entire grid drifts slowly left or right
  - ANIMATION_STYLE=bounce

  # ── Float / bounce settings (bounce + drift styles) ──────────
  - FLOAT_AMPLITUDE=14.0
  - FLOAT_SPEED=0.55

  # ── Wave settings ─────────────────────────────────────────────
  # - WAVE_STAGGER=0.3          # seconds between each poster's entrance

  # ── Pop-in settings ───────────────────────────────────────────
  # - POPIN_SCALE=2.5            # initial scale factor (e.g. 2.5 = 250%)
  # - POPIN_DURATION=1.0         # seconds to scale down to final size
  # - POPIN_STAGGER=0.3          # seconds between each poster's pop

  # ── Carousel settings ─────────────────────────────────────────
  # - CAROUSEL_RX=0.32           # horizontal ellipse radius (fraction of vid width)
  # - CAROUSEL_RY=0.06           # depth offset (fraction of vid height)
  # - CAROUSEL_MIN_SCALE=0.45    # scale of back poster
  # - CAROUSEL_MAX_SCALE=1.0     # scale of front poster

  # ── Spotlight settings ────────────────────────────────────────
  # - SPOTLIGHT_DARKNESS=190     # overlay darkness 0=off  255=solid black
  # - SPOTLIGHT_PAD=1.4          # spotlight radius as multiple of poster size
  # - SPOTLIGHT_INNER=0.55       # fraction of radius that is fully lit (0–1)

  # ── Drift settings ────────────────────────────────────────────
  # - DRIFT_DIRECTION=left       # left | right
  # - DRIFT_SPACING=0.40         # overlap factor: lower = more posters on screen at once
  # - DRIFT_ENTER=0.30           # fraction of slot for entry (edge → centre)
  # - DRIFT_PAUSE=0.22           # fraction of slot paused at centre
  # (exit fraction = 1 - DRIFT_ENTER - DRIFT_PAUSE)

  # ── NeXroll registration ─────────────────────────────────────
  # Registers the rendered video with NeXroll after a successful render.
  # Requires NEXROLL_URL and NEXROLL_API_KEY in docker-compose env.
  - NEXROLL_REGISTER=false
  - NEXROLL_CATEGORY=Coming Soon          # Category name in NeXroll
  - NEXROLL_DISPLAY_NAME=                 # Display name (defaults to output= value)
  - NEXROLL_CREATE_CATEGORY=true          # Create the category if it doesn't exist
  - NEXROLL_APPLY_TO_PLEX=false           # Immediately apply category to Plex after registering
